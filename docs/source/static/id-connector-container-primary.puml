@startuml

title ID-Connector Primary Components\n

!include styling.puml
' skinparam linetype ortho

!include object_importer.puml

frame "DC Primary\n<i>ucs" as primary {
    !include object_ldap.puml
    !include object_listener.puml
    !include object_converter.puml
}


!include object_small_queue.puml
!include object_large_queue.puml

!include object_id_connector.puml

importer --> ldap: <b>write user data\n<i>python
ldap --> listener: <b>call listener on write\n<i>python
listener --> small_queue: <b>Write entryUUIDs\n<b>and change\n<i>JSON
small_queue --> converter:  <b>Read entryUUIDS\n<b>and change\n<i>JSON
converter --> large_queue: <b>Write user data\n<i>JSON
large_queue -->id_connector:<b>Read user data\n<i>JSON

ldap <-- id_connector : <b>Read/write user data\n<i>UDM-REST-API
' id_connector --> ldap
@enduml
